APP_NAME=PixelMind API
APP_VERSION=1.0.0
DEBUG=true

# SQLite for local dev (no Postgres needed)
DATABASE_URL=sqlite:///./pixelmind.db

# JWT Secret
SECRET_KEY=dev-secret-key-change-in-production-256bit-random

# OTP
OTP_EXPIRE_MINUTES=10

# Email (disabled in dev - OTP printed to console)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@pixelmind.app

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# Redis (optional - Celery disabled in dev mode)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Limits
MAX_FILE_SIZE_MB=500
RATE_LIMIT_PER_MINUTE=60
