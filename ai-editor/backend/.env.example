# ═════════════════════════════════════════════
# PIXELMIND API CONFIGURATION
# Copy this file to .env and fill in your values
# ═════════════════════════════════════════════

# App Configuration
APP_NAME=PixelMind API
APP_VERSION=1.0.0
DEBUG=False

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://pixelmind:password@localhost:5432/pixelmind

# ─────────────────────────────────────────────
# SECURITY & JWT
# ─────────────────────────────────────────────
SECRET_KEY=your-256-bit-random-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10

# ─────────────────────────────────────────────
# EMAIL CONFIGURATION (Gmail SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@pixelmind.app

# ─────────────────────────────────────────────
# STORAGE BACKEND
# Choose: "local" (development) or "s3" (production)
# ─────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# ─────────────────────────────────────────────
# AWS S3 (if STORAGE_BACKEND=s3)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=pixelmind-files
AWS_REGION=us-east-1

# ─────────────────────────────────────────────
# REDIS & CELERY (Background Jobs)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─────────────────────────────────────────────
# FILE UPLOAD LIMITS
# ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=500

# ─────────────────────────────────────────────
# FRONTEND URL (for CORS in production)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# DEPLOYMENT URLS (for production)
# ─────────────────────────────────────────────
BACKEND_URL=https://your-backend.onrender.com
FRONTEND_DEPLOY_URL=https://your-frontend.vercel.app
